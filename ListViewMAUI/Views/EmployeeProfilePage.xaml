<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ListViewMAUI.EmployeeProfilePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ListViewMAUI"             
             Title="Employee Profile">

    <ScrollView>
        <Grid Padding="16" RowDefinitions="Auto,*,Auto,Auto">
            
            <!-- Header Section -->
            <Grid Grid.Row="0" 
                  Padding="16"
                  BackgroundColor="{StaticResource Primary}"
                  ColumnDefinitions="120,*">
                
                <!-- Profile Picture -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 60"
                        Stroke="White"
                        StrokeThickness="2"
                        WidthRequest="120"
                        HeightRequest="120">
                    <Image Source="{Binding SelectedEmployee.ImageUrl}"
                           Aspect="AspectFill" />
                </Border>

                <!-- Basic Info -->
                <StackLayout Grid.Column="1" 
                           Margin="16,0,0,0"
                           VerticalOptions="Center">
                    <Label Text="{Binding SelectedEmployee.FullName}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="{Binding SelectedEmployee.Position}"
                           FontSize="16"
                           TextColor="White" />
                    <Label Text="{Binding SelectedEmployee.Department}"
                           FontSize="14"
                           TextColor="LightGray" />
                    <Border BackgroundColor="{Binding SelectedEmployee.IsActive, Converter={StaticResource BoolToColorConverter}}"
                            StrokeShape="RoundRectangle 10"
                            Padding="8,4"
                            HorizontalOptions="Start"
                            Margin="0,8,0,0">
                        <Label Text="{Binding SelectedEmployee.Status}"
                               FontSize="12"
                               TextColor="White" />
                    </Border>
                </StackLayout>
            </Grid>

            <!-- Details Section -->
            <Grid Grid.Row="1" 
                  Margin="0,16,0,0"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  BackgroundColor="White"
                  Padding="16">

                <Label Grid.Row="0"
                       Text="Official Details"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="Black"
                       Margin="0,0,0,12" />

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="Hire Date:" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.DateOfJoining, StringFormat='{0:MMMM dd, yyyy}'}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Skills:" FontAttributes="Bold" VerticalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.SkillsText}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Bio:" FontAttributes="Bold" VerticalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.Bio}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Manager:" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.Manager}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="5" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Experience:" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.YearOfExperience}" Margin="8,0,0,0" />
                </Grid>


                <Grid Grid.Row="6" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="IsVerified:" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.IsVerified}" Margin="8,0,0,0" />
                </Grid>

            </Grid>
            
            
            <!--Personal section-->
            <Grid Grid.Row="2" 
Margin="0,16,0,0"
RowDefinitions="Auto,Auto,Auto,Auto,Auto"
BackgroundColor="White"
Padding="16">

                <Label Grid.Row="0"
     Text="Personal Details"
     FontSize="18"
     FontAttributes="Bold"
     TextColor="Black"
     Margin="0,0,0,12" />

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="First Name:" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.FirstName, StringFormat='{0:MMMM dd, yyyy}'}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Last Name:" FontAttributes="Bold" VerticalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.LastName}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Date Of Birth:" FontAttributes="Bold" VerticalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.DateOfBirth}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Blood Group:" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.BloodGroup}" Margin="8,0,0,0" />
                </Grid>

            </Grid>

            <!-- Contact Section -->
            <Grid Grid.Row="3" 
                  Margin="0,16,0,0"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  BackgroundColor="White"
                  Padding="16">

                <Label Grid.Row="0"
                       Text="Contact Details"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="Black"
                       Margin="0,0,0,12" />

                <Grid Grid.Row="1" ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" Text="Email:" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.Email}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Phone:" FontAttributes="Bold" />
                    <Label  Grid.Column="1" Text="{Binding SelectedEmployee.PhoneNumber}" Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Emergency Phone:" FontAttributes="Bold" />
                    <StackLayout Orientation="Horizontal" Grid.Column="1">
                        <Label Text="{Binding SelectedEmployee.EmergencyPhone}" Margin="8,0,0,0" />
                        <Label Text=" - " Margin="8,0,0,0" />
                        <Label Text="{Binding SelectedEmployee.Relation}" Margin="8,0,0,0" />
                    </StackLayout>
                </Grid>

                <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Address:" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding SelectedEmployee.Address}" Margin="8,0,0,0" />
                </Grid>

            </Grid>
            
        </Grid>
    </ScrollView>
</ContentPage>